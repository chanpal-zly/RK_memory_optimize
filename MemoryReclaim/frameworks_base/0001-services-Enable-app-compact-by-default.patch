+package com.android.server;
+
+import android.app.ActivityManager;
+import android.app.IActivityManager;
+import android.app.job.JobInfo;
+import android.app.job.JobParameters;
+import android.app.job.JobScheduler;
+import android.app.job.JobService;
+import android.content.ComponentName;
+import android.content.Context;
+import android.content.pm.PackageManager;
+import android.os.FileUtils;
+import android.os.SystemProperties;
+import android.os.Process;
+
+import android.util.Slog;
+
+import java.io.File;
+import java.io.FileOutputStream;
+import java.io.IOException;
+import java.util.concurrent.TimeUnit;
+import java.util.Iterator;
+import java.util.List;
+
+/**
+ * Schedules jobs for triggering process reclaim.
+ */
+public final class RockchipProcessCompactor extends JobService {
+    private static final String TAG = "RockchipProcessCompactor";
+    private static final boolean DEBUG = true;
+    //WARNING: This feature may conflict with AppCompact, please check it carefully!
+    private static final boolean USE_PROCESS_COMPACTOR = false;
+
+    private static final ComponentName sRockchipProcessCompactor =
+            new ComponentName("android", RockchipProcessCompactor.class.getName());
+
+    private static final int MARK_IDLE_JOB_ID = 813;
+    private static final int PROC_COMPACT_IDLE_JOB_ID = 814;
+    private static final int DEFAULT_DELAY_TIME_MINUTES = 5;
+
+    private static final String NATIVE_PROC_COMPACT_SERVICE_NAME = "rockchip.reclaimd";
+    private static final String MARK_IDLE_DELAY_PROP = "persist.proc_compact.mark_idle_delay_mins";
+    private static final String FIRST_WB_DELAY_PROP = "persist.proc_compact.first_pc_delay_mins";
+    private static final String PERIODIC_PROC_COMPACT_DELAY_PROP = "persist.proc_compact.periodic_pc_delay_mins";
+
+    private static final String MEM_LEVEL_PROP = "persist.proc_compact.memory_required";
+    private static final String USE_PROC_COMPACT_PROP = "persist.proc_compact.enable";
+    private static final String USE_PROC_APP_COMPACT_PROP = "persist.proc_compact.app_enable";
+
+    private static final String FORCE_PROC_COMPACT_PROP = "persist.proc_compact.force_reclaim";
+    private static String[] mSpecialPackages = {"com.android","com.google"};
+
+    // Return memory level for required.
+    // Currently, return 500M(60%) for 1GB devices.
+    // KB
+    private long getMemLevelRequired() {
+        long memoryLevel = 1024L * SystemProperties.getInt(MEM_LEVEL_PROP, 500);
+        Slog.e(TAG, "Total memory: " + Process.getTotalMemory());
+        return memoryLevel;
+    }
+
+    // Return current memory status, free, cached...
+    // KB
+    private long getCurrentMemAvailable() {
+        long freeMem = Process.getFreeMemory();
+        long homeAppMem = 0L;
+        final IActivityManager am = ActivityManager.getService();
+        try {
+            ActivityManager.MemoryInfo info = new ActivityManager.MemoryInfo();
+            am.getMemoryInfo(info);
+            homeAppMem = info.threshold;
+        } catch (Exception e) {}
+
+        Slog.e(TAG, "Free memory: " + freeMem + ", Home App memory: " + homeAppMem);
+        return freeMem + homeAppMem;
+    }
+
+    // Current memory is enough, no need to reclaim process memory.
+    private void markMemIsEnough() {
+        if (DEBUG) Slog.d(TAG, "markMemIsEnough, IDLE job....");
+    }
+
+    private void doReclaimProcess(int pid, String action) {
+        if (DEBUG) Slog.d(TAG, "Trigger [" + action + "] reclaim for pid: " + pid);
+        try (FileOutputStream fos = new FileOutputStream("/proc/" + pid + "/reclaim")) {
+            fos.write(action.getBytes());
+        } catch (Exception e) {
+            Slog.e(TAG, "Error writing reclaim node!!!!!" + e.toString());
+        }
+    }
+
+    private boolean isProtectPackage(String packageName) {
+        for (String name : mSpecialPackages) {
+            if (packageName.contains(name)) {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    private boolean shouldReclaimProcess(ActivityManager.RunningAppProcessInfo info) {
+        if (DEBUG) Slog.d(TAG, "pid: " + info.pid + "(" + info.processName + ")");
+        if (info.isFocused) {
+            Slog.w(TAG, "Current app is focused, should not reclaim.");
+            return false;
+        }
+        return true;
+    }
+
+    private void doNativeProcessReclaim() {
+        Slog.i(TAG, "Do native process reclaim...check logcat TAG: RockchipReclaimD");
+        SystemProperties.set("ctl.start", NATIVE_PROC_COMPACT_SERVICE_NAME);
+    }
+
+    private void doProcessReclaimUntilReachMemLevel() {
+        // Start Native compact.
+        doNativeProcessReclaim();
+
+        if (!isAppCompactorEnable()) return;
+
+        // Start App compact
+        long oldMem = getCurrentMemAvailable();
+        ActivityManager am = (ActivityManager)this.getSystemService(Context.ACTIVITY_SERVICE);
+        PackageManager pm = this.getPackageManager();
+        List l = am.getRunningAppProcesses();
+        Iterator i = l.iterator();
+        while (i.hasNext()) {
+            ActivityManager.RunningAppProcessInfo info = (ActivityManager.RunningAppProcessInfo)(i.next());
+            if (DEBUG) Slog.d(TAG, "List current process: " + info.processName + "(" + info.pid + ")");
+            if (shouldReclaimProcess(info)) {
+                doReclaimProcess(info.pid, "all");
+            }
+            if (!isAppCompactorEnable() && getCurrentMemAvailable() <= getMemLevelRequired()) {
+                Slog.e(TAG, "doProcessReclaimUntilReachMemLevel is finished...");
+                break;
+            }
+            try {
+                Thread.sleep(1000);
+            } catch (Exception e) {
+            }
+        }
+        markMemIsEnough();
+        if (oldMem != -1) {
+            Slog.i(TAG, "Freed memory is about " + (getCurrentMemAvailable() - oldMem)/1024 + "KB.");
+        }
+    }
+
+    public static boolean isProcessCompactorEnabled() {
+        boolean enabled = SystemProperties.getBoolean(USE_PROC_COMPACT_PROP, USE_PROCESS_COMPACTOR);
+        return enabled;
+    }
+
+    public static boolean isAppCompactorEnable() {
+        boolean enabled = SystemProperties.getBoolean(USE_PROC_APP_COMPACT_PROP, USE_PROCESS_COMPACTOR);
+        return isProcessCompactorEnabled() && enabled;
+    }
+
+    private static void schedNextProcessCompact(Context context) {
+        int nextProcReclaimDelay = SystemProperties.getInt(PERIODIC_PROC_COMPACT_DELAY_PROP, DEFAULT_DELAY_TIME_MINUTES);
+        boolean forceProcReclaim = SystemProperties.getBoolean(FORCE_PROC_COMPACT_PROP, true);
+        JobScheduler js = (JobScheduler) context.getSystemService(Context.JOB_SCHEDULER_SERVICE);
+
+        js.schedule(new JobInfo.Builder(PROC_COMPACT_IDLE_JOB_ID, sRockchipProcessCompactor)
+                        .setMinimumLatency(TimeUnit.MINUTES.toMillis(nextProcReclaimDelay))
+                        .setRequiresDeviceIdle(!forceProcReclaim)
+                        .build());
+    }
+
+    @Override
+    public boolean onStartJob(JobParameters params) {
+        if (DEBUG) Slog.d(TAG, "StartJob: " + TAG + ", id: " + params.getJobId());
+        if (!isProcessCompactorEnabled()) {
+            jobFinished(params, false);
+            return false;
+        }
+
+        if (params.getJobId() == MARK_IDLE_JOB_ID) {
+            markMemIsEnough();
+            jobFinished(params, false);
+            return false;
+        } else {
+            new Thread("RockchipProcessCompactor_Reclaim_Process") {
+                @Override
+                public void run() {
+                    doProcessReclaimUntilReachMemLevel();
+                    schedNextProcessCompact(RockchipProcessCompactor.this);
+                    jobFinished(params, false);
+                }
+            }.start();
+        }
+        return true;
+    }
+
+    @Override
+    public boolean onStopJob(JobParameters params) {
+        // The thread that triggers the reclaim is non-interruptible
+        return false;
+    }
+
+    /**
+     * Schedule the process compact job to trigger a process when idle
+     * This func is triggered by OnSystemReady()
+     */
+    public static void scheduleRockchipProcessCompactor(Context context) {
+        Slog.i(TAG, "OnSystemReady-->scheduleRockchipProcessCompactor");
+        int markIdleDelay = SystemProperties.getInt(MARK_IDLE_DELAY_PROP, DEFAULT_DELAY_TIME_MINUTES);
+        int firstProcCompactDelay = SystemProperties.getInt(FIRST_WB_DELAY_PROP, 3);
+        boolean forceProcReclaim = SystemProperties.getBoolean(FORCE_PROC_COMPACT_PROP, true);
+
+        JobScheduler js = (JobScheduler) context.getSystemService(Context.JOB_SCHEDULER_SERVICE);
+
+        // Schedule a one time job to mark pages as idle.
+        js.schedule(new JobInfo.Builder(MARK_IDLE_JOB_ID, sRockchipProcessCompactor)
+                        .setMinimumLatency(TimeUnit.MINUTES.toMillis(markIdleDelay))
+                        .setOverrideDeadline(TimeUnit.MINUTES.toMillis(markIdleDelay))
+                        .build());
+
+        // Schedule a one time job to compact process.
+        js.schedule(new JobInfo.Builder(PROC_COMPACT_IDLE_JOB_ID, sRockchipProcessCompactor)
+                        .setMinimumLatency(TimeUnit.MINUTES.toMillis(firstProcCompactDelay))
+                        .setRequiresDeviceIdle(!forceProcReclaim)
+                        .build());
+    }
+}
